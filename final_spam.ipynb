    "plt.figure()\n",
    "plt.bar(x - width/2, svm_scores, width, label=\"SVM\")\n",
    "plt.bar(x + width/2, lgbm_scores, width, label=\"LightGBM\")\n",
    "\n",
    "plt.xticks(x, labels)\n",
    "plt.ylim(0, 1)\n",
    "plt.xlabel(\"Class\")\n",
    "plt.ylabel(\"Confidence\")\n",
    "plt.title(\"HAM vs SPAM Confidence (SVM vs LightGBM)\")\n",
    "plt.legend()\n",
    "plt.show()\n"
