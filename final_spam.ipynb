    "\n",
    "svm_scores = [svm_ham_prob, svm_spam_prob]\n",
    "lgbm_scores = [lgbm_ham_prob, lgbm_spam_prob]\n",
    "\n",
    "x = np.arange(len(labels))\n",
    "width = 0.35\n",
